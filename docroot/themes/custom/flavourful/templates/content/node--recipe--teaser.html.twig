{#
/**
 * @file
 * Recipe teaser — the rows of the /recipes View (grid style, entity:node row).
 *
 * Renders the shared `recipe-card` Single Directory Component. The SDC owns the
 * markup, styles and props/slots contract; this template's only job is to map
 * node fields onto it. The exact same component renders on the full node page
 * (node--recipe.html.twig) — edit the component once, both update.
 *
 * - The hero image goes into the `media` slot as a rendered field so its image
 *   style, alt text and cacheability are preserved; a placeholder fills the
 *   slot when field_hero is empty.
 * - Diet terms go into the `tags` slot as `tag-pill` atoms (components inside a
 *   slot — the thing props can't do).
 *
 * @see template_preprocess_node()
 */
#}
{% set card_props = {
  title: label,
  url: url,
  eyebrow: node.field_recipe_cuisine_type.entity.label|default(''),
  summary: node.field_summary.value|default(''),
  cooking_time: (node.field_cooking_time.value|default(0)) + 0,
} %}
{# difficulty is an enum prop: only pass it when set, or schema validation fails. #}
{% if node.field_difficulty.value %}
  {% set card_props = card_props|merge({ difficulty: node.field_difficulty.value }) %}
{% endif %}

{% embed 'flavourful:recipe-card' with card_props %}
  {% block media %}
    {% if content.field_hero|render|trim is not empty %}
      {{ content.field_hero }}
    {% else %}
      <span class="recipe-card__placeholder">🍽️</span>
    {% endif %}
  {% endblock %}

  {% block tags %}
    {% for tag in node.field_type_of_diet %}
      {{ include('flavourful:tag-pill', { label: tag.entity.label }, with_context = false) }}
    {% endfor %}
  {% endblock %}
{% endembed %}
