# =============================================================================
# .gitignore — Drupal Composer project (docroot: docroot/)
# -----------------------------------------------------------------------------
# Everything ignored here is either managed by Composer (rebuild with
# `composer install`), generated at runtime, or environment-specific/sensitive.
# Commit composer.json + composer.lock and custom code; do NOT commit the
# vendored dependencies below.
# =============================================================================

# --- Composer-managed dependencies -------------------------------------------
/vendor/
/docroot/core/
/docroot/modules/contrib/
/docroot/profiles/contrib/
/docroot/themes/contrib/
/docroot/libraries/

# --- Environment-specific / sensitive settings -------------------------------
# Keep the *.example / default templates, ignore the real ones (DB creds, hash
# salt, local overrides). settings.php is committed (environment-aware, no
# secrets) so it ships in the deploy artifact; the per-environment/secret files
# below stay ignored (DDEV rewrites settings.ddev.php on `ddev start`).
/docroot/sites/*/settings.local.php
/docroot/sites/*/settings.ddev.php
/docroot/sites/*/services.yml
!/docroot/sites/*/default.settings.php
!/docroot/sites/*/default.services.yml

# --- User-generated & runtime content ----------------------------------------
/docroot/sites/*/files/
/docroot/sites/*/private/
/docroot/sites/simpletest/

# --- Front-end build artifacts (Node) ----------------------------------------
node_modules/
*.css.map

# --- OS / editor cruft --------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Claude Code local settings (machine-specific)
/.claude/settings.local.json

docroot/themes/custom/flavourful/images/icons/
